{
  "name": "@complexthings/pi-dynamic-context-pruning",
  "version": "1.0.7",
  "description": "PI coding agent extension \u2014 Dynamic Context Pruning (DCP)",
  "keywords": [
    "pi-package",
    "pi-extension",
    "coding-agent",
    "dynamic-context-pruning",
    "dcp",
    "context",
    "pruning"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "author": {
    "name": "Greg",
    "email": "greg.harvell@complexthings.com",
    "url": "https://github.com/complexthings"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/complexthings/pi-dynamic-context-pruning.git"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,md,json,jsonc,cjs,mjs}\"",
    "ci": "bun run check-types && bun run lint && bun run test",
    "prepare": "husky"
  }
}
